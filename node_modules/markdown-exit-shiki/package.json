  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Efterklang/markdown-exit-shiki.git"
  },
  "homepage": "https://github.com/Efterklang/markdown-exit-shiki#readme",
  "bugs": "https://github.com/Efterklang/markdown-exit-shiki/issues",
  "scripts": {
    "test": "bun test ./test/index.test.ts",
    "build": "vite build",
    "lint": "biome check --write ."
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
