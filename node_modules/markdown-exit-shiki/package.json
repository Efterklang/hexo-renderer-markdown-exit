  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "markdown-exit": "^1.0.0-beta.9",
    "@shikijs/transformers": "^4.0.2",
    "@shikijs/colorized-brackets": "^4.0.2",
    "shiki": "^4.0.2"
  }
}
